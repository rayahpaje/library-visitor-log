{
  "entities": {
    "Visitor": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Visitor",
      "type": "object",
      "description": "Represents an individual visitor to the library.",
      "properties": {
        "id": { "type": "string" },
        "institutionalId": { "type": "string" },
        "name": { "type": "string" },
        "college": { "type": "string" },
        "purpose": { "type": "string" },
        "timeIn": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["name", "institutionalId", "college", "purpose", "timeIn"]
    },
    "BlockEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BlockEntry",
      "type": "object",
      "description": "Records of blocked visitors.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "institutionalId": { "type": "string" },
        "reason": { "type": "string" },
        "dateBlocked": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "institutionalId", "reason", "dateBlocked"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/visitors/{visitorId}",
        "definition": {
          "entityName": "Visitor",
          "schema": { "$ref": "#/backend/entities/Visitor" },
          "description": "Visitor entry logs."
        }
      },
      {
        "path": "/blockList/{blockId}",
        "definition": {
          "entityName": "BlockEntry",
          "schema": { "$ref": "#/backend/entities/BlockEntry" },
          "description": "List of restricted library visitors."
        }
      }
    ]
  }
}