rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU LIBRARY VISITOR MANAGEMENT - PROTOTYPE RULES
     * 
     * These rules are optimized for the prototype phase, allowing authenticated
     * staff members to read and write institutional records.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Admin Roles - allow authenticated users to check status
    match /roles_admin/{adminId} {
      allow get, list: if isSignedIn();
      allow write: if false; // Managed via console or functions
    }

    // Predefined Purposes
    match /purposes/{purposeId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    // Visitor Profiles and Logs
    match /visitors/{visitorId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // Security Block List (formerly blockEntries)
    match /blockList/{blockId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // Historical Logs
    match /visitLogs/{visitLogId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}