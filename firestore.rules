rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU LIBRARY VISITOR MANAGEMENT - SECURITY RULES
     * 
     * Allows public creation of visitor logs for the entry portal.
     * Restricted data (blockList, full visitor history) requires staff authentication.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Admin Roles
    match /roles_admin/{adminId} {
      allow get, list: if isSignedIn();
      allow write: if false; 
    }

    // Visitor Entries
    match /visitors/{visitorId} {
      // Allow library staff to view all logs
      allow get, list: if isSignedIn();
      // Allow the public portal to create new logs
      allow create: if true;
      // Only staff can update or delete entry records
      allow update, delete: if isSignedIn();
    }

    // Security Block List
    match /blockList/{blockId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}